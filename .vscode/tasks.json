{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Python: Install requirements",
      "type": "shell",
      "command": "${command:python.interpreterPath}",
      "args": [
        "-m",
        "pip",
        "install",
        "-r",
        "requirements.txt"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "MMM: Load benchmarks",
      "type": "shell",
      "command": "${command:python.interpreterPath}",
      "args": [
        "-m",
        "src.main_load_benchmarks"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "MMM: Generate demo data",
      "type": "shell",
      "command": "${command:python.interpreterPath}",
      "args": [
        "-m",
        "src.main_generate_demo_data"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "MMM: Run scenario_001",
      "type": "shell",
      "command": "${command:python.interpreterPath}",
      "args": [
        "-m",
        "src.main_run_scenario",
        "scenario_001"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "MMM: Prepare demo data",
      "dependsOn": [
        "MMM: Load benchmarks",
        "MMM: Generate demo data",
        "MMM: Run scenario_001"
      ],
      "dependsOrder": "sequence",
      "problemMatcher": []
    }
  ]
}
