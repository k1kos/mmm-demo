{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "MMM: Load benchmarks",
      "type": "debugpy",
      "request": "launch",
      "module": "src.main_load_benchmarks",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "MMM: Generate demo data",
      "type": "debugpy",
      "request": "launch",
      "module": "src.main_generate_demo_data",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "MMM: Run scenario_001",
      "type": "debugpy",
      "request": "launch",
      "module": "src.main_run_scenario",
      "args": [
        "scenario_001"
      ],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "MMM: Streamlit app",
      "type": "debugpy",
      "request": "launch",
      "module": "streamlit",
      "args": [
        "run",
        "app.py"
      ],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "MMM: Prepare + Streamlit",
      "type": "debugpy",
      "request": "launch",
      "module": "streamlit",
      "args": [
        "run",
        "app.py"
      ],
      "preLaunchTask": "MMM: Prepare demo data",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true
    }
  ]
}
